<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenVoicer.Views.SettingsWindow"
        Title="Настройки OpenVoicer" SizeToContent="Height" Width="420"
        MaxHeight="700"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#F5F5F7">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Настройки" Foreground="#222" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Подключение к Voicer и управление OpenCode" Foreground="#999" FontSize="12" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Voicer section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="VOICER" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid ColumnDefinitions="120,*">
                    <TextBlock Grid.Column="0" Text="WS порт" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="VoicerPortTextBox" Width="80" HorizontalAlignment="Left"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- OpenCode section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="OPENCODE" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Порт" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="OpenCodePortTextBox" Width="80" HorizontalAlignment="Left"/>
                    </Grid>
                    <CheckBox x:Name="AutoStartCheckBox" Content="Запускать OpenCode при старте"/>
                    <StackPanel x:Name="WslSection" Spacing="8">
                        <CheckBox x:Name="UseWslCheckBox" Content="Запускать через WSL2" Checked="UseWsl_Changed" Unchecked="UseWsl_Changed"/>
                        <Grid ColumnDefinitions="120,*" x:Name="WslDistroGrid" IsVisible="False">
                            <TextBlock Grid.Column="0" Text="WSL дистрибутив" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="WslDistroTextBox" Watermark="по умолчанию" HorizontalAlignment="Stretch"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" x:Name="WslWorkDirGrid" IsVisible="False">
                            <TextBlock Grid.Column="0" Text="Рабочий каталог" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="WslWorkDirTextBox" Watermark="~ (домашний каталог)" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Model section -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="МОДЕЛЬ" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Провайдер" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="ProviderComboBox" HorizontalAlignment="Stretch"
                                  SelectionChanged="Provider_SelectionChanged"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Модель" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="ModelComboBox" HorizontalAlignment="Stretch"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <TextBlock x:Name="ModelStatusText" Foreground="#999" FontSize="11"
                                   VerticalAlignment="Center"
                                   Text="Загрузка списка провайдеров..."/>
                        <Button x:Name="RefreshButton" Content="⟳ Обновить" FontSize="11"
                                Padding="8,2" Click="Refresh_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Agent section -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14">
            <TextBlock Text="АГЕНТ" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Агент" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="AgentComboBox" HorizontalAlignment="Stretch"/>
                    </Grid>
                    <TextBlock x:Name="AgentDescText" Foreground="#999" FontSize="11" Margin="0,2,0,0"
                               TextWrapping="Wrap" MaxWidth="340"
                               Text="Загрузка списка агентов..."/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Notifications section -->
        <StackPanel Grid.Row="5" Margin="0,0,0,14">
            <TextBlock Text="УВЕДОМЛЕНИЯ" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="8">
                    <CheckBox x:Name="ShowPopupCheckBox" Content="Показывать уведомления" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Длительность" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="PopupDurationTextBox" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Text="сек (0.5–30)" Foreground="#999" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Макс. символов" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="PopupMaxLengthTextBox" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Text="0 = без лимита" Foreground="#999" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тег новой сессии" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="NewSessionTagTextBox" Width="140" HorizontalAlignment="Left"/>
                    </Grid>
                    <CheckBox x:Name="AutoStartCheckBox2" Content="Запускать при загрузке системы"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Отмена" Width="90" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="90" Click="Save_Click" Classes="accent"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
