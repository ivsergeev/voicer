<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenVoicer.Views.NotificationPopup"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        MaxWidth="400"
        PointerPressed="Window_PointerPressed">
    <Border x:Name="PopupBorder" CornerRadius="8" Padding="14,10"
            BorderBrush="#60FFFFFF" BorderThickness="1">
        <StackPanel Spacing="4">
            <!-- Header: dot + title + badge -->
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock x:Name="StatusDot" Text="●" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border x:Name="BadgePill" CornerRadius="4" Padding="6,2" Background="#40FFFFFF"
                        IsVisible="False" VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock x:Name="BadgeText" Foreground="White" FontSize="11" FontWeight="Medium"/>
                </Border>
            </StackPanel>

            <!-- Description -->
            <TextBlock x:Name="DescriptionText"
                       Foreground="#DDFFFFFF"
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       IsVisible="False"/>

            <!-- Action buttons -->
            <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" Spacing="8"
                        Margin="0,4,0,0" IsVisible="False">
                <Button x:Name="RejectButton" Content="Отклонить" FontSize="12" Padding="12,4"
                        Click="Reject_Click"/>
                <Button x:Name="ApproveButton" Content="Разрешить" FontSize="12" Padding="12,4"
                        Click="Approve_Click" Classes="accent"/>
                <Button x:Name="CloseButton" Content="Закрыть" FontSize="12" Padding="12,4"
                        Click="Close_Click" IsVisible="False"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
