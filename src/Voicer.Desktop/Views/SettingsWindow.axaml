<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Voicer.Desktop.Views.SettingsWindow"
        Title="Voicer Settings" SizeToContent="Height" Width="460"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#F5F5F7">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Settings" Foreground="#222" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Configure voice recognition and hotkeys" Foreground="#999" FontSize="12" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Audio section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="AUDIO" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="120,*">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Microphone" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="MicrophoneCombo" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Threads" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ThreadsTextBox" Width="60" HorizontalAlignment="Left"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Hotkeys section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="HOTKEYS" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="120,*">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="WebSocket" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="HotkeyTextBox"
                             IsReadOnly="True" Margin="0,0,0,8" Cursor="Hand"
                             KeyDown="HotkeyTextBox_KeyDown"
                             GotFocus="HotkeyTextBox_GotFocus"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Insert at cursor" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="InsertHotkeyTextBox"
                             IsReadOnly="True" Cursor="Hand"
                             KeyDown="InsertHotkeyTextBox_KeyDown"
                             GotFocus="InsertHotkeyTextBox_GotFocus"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- General section -->
        <StackPanel Grid.Row="3" Margin="0,0,0,0">
            <TextBlock Text="GENERAL" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Background="White" CornerRadius="6" Padding="14,12" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <Grid ColumnDefinitions="120,*" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="WS Port" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="PortTextBox" Width="80" HorizontalAlignment="Left"/>
                    </Grid>
                    <CheckBox x:Name="ShowPopupCheckBox" Content="Show transcription popup" Margin="0,0,0,8"/>
                    <CheckBox x:Name="AutostartCheckBox" Content="Start with system"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="90" Click="Save_Click" Classes="accent"/>
        </StackPanel>
    </Grid>
</Window>
